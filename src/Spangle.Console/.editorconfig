# Blazor WASM console relaxations on top of the root policy. Reasons:
# - WASM is single-threaded and components resume on the renderer's context;
#   ConfigureAwait(false) in UI code is pure noise (CA2007, MA0004)
# - The Blazor router discovers page components; public is its convention (CA1515)

[*.cs]
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.MA0004.severity = none
dotnet_diagnostic.CA1515.severity = none
