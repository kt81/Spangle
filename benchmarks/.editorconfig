# Benchmark-project relaxations on top of the root policy. Reasons:
# - BenchmarkDotNet requires public benchmark classes (CA1515)
# - Random generates test payloads, not security material (CA5394)
# - No synchronization context in the benchmark host (CA2007, MA0004)
# - Fixture buffers live for the whole benchmark process (CA1001)

[*.cs]
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA5394.severity = none
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.MA0004.severity = none
dotnet_diagnostic.CA1001.severity = none
